<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.money.cloud.monee.mapper.BudgetMapper">

    <select id="selectByUserIdAndMonth" resultType="com.money.cloud.monee.entity.Budget">
        SELECT id, user_id, month, amount, created_at, updated_at
        FROM budgets
        WHERE user_id = #{userId}
          AND month = #{month}
        LIMIT 1
    </select>

</mapper>
